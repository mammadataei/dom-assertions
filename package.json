{
  "name": "@testing-library/dom-assertions",
  "version": "0.0.0-semantically-released",
  "description": "Accessible DOM assertions for testing user interfaces.",
  "author": "Mohammad Ataei <mammadataei@gmail.com>",
  "license": "MIT",
  "keywords": [
    "testing",
    "dom",
    "assertions",
    "accessible",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/testing-library/dom-assertions/"
  },
  "bugs": {
    "url": "https://github.com/testing-library/dom-assertions/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,md,html,css}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.3",
    "@commitlint/config-conventional": "^17.0.3",
    "@testing-library/dom": "^8.14.0",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "c8": "^7.11.3",
    "eslint": "^8.18.0",
    "eslint-config-prettier": "^8.5.0",
    "husky": "^8.0.1",
    "jsdom": "^20.0.0",
    "lint-staged": "^13.0.3",
    "prettier": "2.7.1",
    "tsup": "^6.1.2",
    "typescript": "^4.7.4",
    "vite": "^2.9.13",
    "vitest": "^0.16.0"
  },
  "dependencies": {
    "dom-accessibility-api": "^0.5.14"
  }
}
